{
	"name": "backend",
	"version": "1.0.50",
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build src/index.ts --compile --minify-whitespace --minify-syntax --target bun --outfile dist/server --compile-autoload-package-json",
		"start": "./dist/server",
		"lint": "eslint .",
		"check-types": "tsc --noEmit",
		"test": "bun test",
		"test:phase1": "bun test src/__tests__/phase1",
		"db:migrate": "kysely migrate latest",
		"db:migrate:make": "kysely migrate:make",
		"db:migrate:list": "kysely migrate list",
		"db:migrate:down": "kysely migrate down",
		"db:migrate:rollback": "kysely migrate rollback --all",
		"db:typegen": "kysely-codegen --out-file ./src/shared/infrastructure/database/types.ts --camel-case",
		"db:sync": "bun run db:migrate && bun run db:typegen",
		"db:typecheck": "kysely-codegen --out-file ./src/shared/infrastructure/database/types.ts --verify --camel-case"
	},
	"dependencies": {
		"elysia": "latest",
		"ioredis": "^5.4.0",
		"kysely": "^0.29.0",
		"pg": "^8.11.3",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"postgres": "^3.4.9"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@repo/eslint-config": "workspace:*",
		"@repo/typescript-config": "workspace:*",
		"@types/pg": "^8.20.0",
		"bun-types": "latest",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-turbo": "^2.9.12",
		"kysely-codegen": "^0.20.0",
		"kysely-ctl": "^0.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3"
	},
	"module": "src/index.js"
}
